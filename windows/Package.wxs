<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org"
     xmlns:ui="http://wixtoolset.org/ui">

  <Package Name="Metronome"
           Manufacturer="YourStudio"
           Version="1.0.0.0"
           UpgradeCode="7E579F21-E8A4-4A8E-9B3B-8C9B9A1A2B3C"
           Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Icon Id="AppIcon" SourceFile="$(var.SourceDir)\data\flutter_assets\assets\images\app_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <Feature Id="Main">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Metronome">
        <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-4789-8C9D-EF1234567890">
          <File Id="MetronomeExe" Source="$(var.SourceDir)\metronome.exe" KeyPath="yes" />
        </Component>
        <Component Id="FlutterWindowsDll" Guid="B2C3D4E5-F6A7-4890-9D8E-F12345678901">
          <File Source="$(var.SourceDir)\flutter_windows.dll" />
        </Component>
        <Component Id="FlutterSoloudPluginDll" Guid="C3D4E5F6-A7B8-4901-9E8F-123456789012">
          <File Source="$(var.SourceDir)\flutter_soloud_plugin.dll" />
        </Component>
        <Component Id="WindowManagerPluginDll" Guid="D4E5F6A7-B8C9-4012-9F8E-234567890123">
          <File Source="$(var.SourceDir)\window_manager_plugin.dll" />
        </Component>
        <Component Id="ScreenRetrieverPluginDll" Guid="E5F6A7B8-C9D0-4123-AF9E-345678901234">
          <File Source="$(var.SourceDir)\screen_retriever_windows_plugin.dll" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="F6A7B8C9-D0E1-4234-BF9A-456789012345">
        <Shortcut Id="DesktopShortcut"
                  Name="Metronome"
                  Description="Professional Metronome App"
                  Target="[INSTALLFOLDER]metronome.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\YourStudio\Metronome"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcutComponent" Guid="A7B8C9D0-E1F2-4356-CB0A-567890123456">
        <Shortcut Id="StartMenuShortcut"
                  Name="Metronome"
                  Description="Professional Metronome App"
                  Target="[INSTALLFOLDER]metronome.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
      </Component>
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="Metronome" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="FlutterWindowsDll" />
      <ComponentRef Id="FlutterSoloudPluginDll" />
      <ComponentRef Id="WindowManagerPluginDll" />
      <ComponentRef Id="ScreenRetrieverPluginDll" />
      <ComponentRef Id="DesktopShortcutComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDir="INSTALLFOLDER" />
  </Package>
</Wix>
