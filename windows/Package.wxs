<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Metronome"
           Manufacturer="YourStudio"
           Version="1.0.0.0"
           UpgradeCode="7E579F21-E8A4-4A8E-9B3B-8C9B9A1A2B3C"
           Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.SourceDir)/app_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <Feature Id="Main">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentGroupRef Id="DataComponents" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Metronome">
        <Directory Id="DataFolder" Name="data">
        <Component Id="C_app_so" Guid="*"><File Id="F_C_app_so" Source="$(var.SourceDir)/data/app.so" KeyPath="yes" /></Component>
        <Component Id="C_icudtl_dat" Guid="*"><File Id="F_C_icudtl_dat" Source="$(var.SourceDir)/data/icudtl.dat" KeyPath="yes" /></Component>
        <Directory Id="D_flutter_assets" Name="flutter_assets">
          <Component Id="C_flutter_assets_AssetManifest_bin" Guid="*"><File Id="F_C_flutter_assets_AssetManifest_bin" Source="$(var.SourceDir)/data/flutter_assets/AssetManifest.bin" KeyPath="yes" /></Component>
          <Component Id="C_flutter_assets_FontManifest_json" Guid="*"><File Id="F_C_flutter_assets_FontManifest_json" Source="$(var.SourceDir)/data/flutter_assets/FontManifest.json" KeyPath="yes" /></Component>
          <Component Id="C_flutter_assets_NativeAssetsManifest_json" Guid="*"><File Id="F_C_flutter_assets_NativeAssetsManifest_json" Source="$(var.SourceDir)/data/flutter_assets/NativeAssetsManifest.json" KeyPath="yes" /></Component>
          <Component Id="C_flutter_assets_NOTICES_Z" Guid="*"><File Id="F_C_flutter_assets_NOTICES_Z" Source="$(var.SourceDir)/data/flutter_assets/NOTICES.Z" KeyPath="yes" /></Component>
          <Directory Id="D_flutter_assets_assets" Name="assets">
            <Component Id="C_flutter_assets_assets_help_zh_md" Guid="*"><File Id="F_C_flutter_assets_assets_help_zh_md" Source="$(var.SourceDir)/data/flutter_assets/assets/help_zh.md" KeyPath="yes" /></Component>
            <Directory Id="D_flutter_assets_assets_sounds" Name="sounds">
              <Directory Id="D_flutter_assets_assets_sounds_drum" Name="drum">
                <Component Id="C_flutter_assets_assets_sounds_drum_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_drum_click_high_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/drum/click_high.wav" KeyPath="yes" /></Component>
                <Component Id="C_flutter_assets_assets_sounds_drum_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_drum_click_low_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/drum/click_low.wav" KeyPath="yes" /></Component>
              </Directory>
              <Directory Id="D_flutter_assets_assets_sounds_electronic" Name="electronic">
                <Component Id="C_flutter_assets_assets_sounds_electronic_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_electronic_click_high_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/electronic/click_high.wav" KeyPath="yes" /></Component>
                <Component Id="C_flutter_assets_assets_sounds_electronic_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_electronic_click_low_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/electronic/click_low.wav" KeyPath="yes" /></Component>
              </Directory>
              <Directory Id="D_flutter_assets_assets_sounds_mechanical" Name="mechanical">
                <Component Id="C_flutter_assets_assets_sounds_mechanical_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_mechanical_click_high_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/mechanical/click_high.wav" KeyPath="yes" /></Component>
                <Component Id="C_flutter_assets_assets_sounds_mechanical_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_mechanical_click_low_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/mechanical/click_low.wav" KeyPath="yes" /></Component>
              </Directory>
              <Directory Id="D_flutter_assets_assets_sounds_voice" Name="voice">
                <Component Id="C_flutter_assets_assets_sounds_voice_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_voice_click_high_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/voice/click_high.wav" KeyPath="yes" /></Component>
                <Component Id="C_flutter_assets_assets_sounds_voice_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_voice_click_low_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/voice/click_low.wav" KeyPath="yes" /></Component>
              </Directory>
              <Directory Id="D_flutter_assets_assets_sounds_woodblock" Name="woodblock">
                <Component Id="C_flutter_assets_assets_sounds_woodblock_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_woodblock_click_high_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/woodblock/click_high.wav" KeyPath="yes" /></Component>
                <Component Id="C_flutter_assets_assets_sounds_woodblock_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_woodblock_click_low_wav" Source="$(var.SourceDir)/data/flutter_assets/assets/sounds/woodblock/click_low.wav" KeyPath="yes" /></Component>
              </Directory>
            </Directory>
          </Directory>
          <Directory Id="D_flutter_assets_fonts" Name="fonts">
            <Component Id="C_flutter_assets_fonts_MaterialIcons_Regular_otf" Guid="*"><File Id="F_C_flutter_assets_fonts_MaterialIcons_Regular_otf" Source="$(var.SourceDir)/data/flutter_assets/fonts/MaterialIcons-Regular.otf" KeyPath="yes" /></Component>
          </Directory>
          <Directory Id="D_flutter_assets_packages" Name="packages">
            <Directory Id="D_flutter_assets_packages_cupertino_icons" Name="cupertino_icons">
              <Directory Id="D_flutter_assets_packages_cupertino_icons_assets" Name="assets">
                <Component Id="C_flutter_assets_packages_cupertino_icons_assets_CupertinoIcons_ttf" Guid="*"><File Id="F_C_flutter_assets_packages_cupertino_icons_assets_CupertinoIcons_ttf" Source="$(var.SourceDir)/data/flutter_assets/packages/cupertino_icons/assets/CupertinoIcons.ttf" KeyPath="yes" /></Component>
              </Directory>
            </Directory>
            <Directory Id="D_flutter_assets_packages_flutter_soloud" Name="flutter_soloud">
            </Directory>
          </Directory>
          <Directory Id="D_flutter_assets_shaders" Name="shaders">
            <Component Id="C_flutter_assets_shaders_ink_sparkle_frag" Guid="*"><File Id="F_C_flutter_assets_shaders_ink_sparkle_frag" Source="$(var.SourceDir)/data/flutter_assets/shaders/ink_sparkle.frag" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_shaders_stretch_effect_frag" Guid="*"><File Id="F_C_flutter_assets_shaders_stretch_effect_frag" Source="$(var.SourceDir)/data/flutter_assets/shaders/stretch_effect.frag" KeyPath="yes" /></Component>
          </Directory>
        </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="A1B2C3D4-E5F6-4789-8C9D-EF1234567890">
        <Shortcut Id="DesktopShortcut"
                  Name="Metronome"
                  Description="Professional Metronome App"
                  Target="[!MetronomeExe]"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU" Key="Software\YourStudio\Metronome" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*">
        <File Id="MetronomeExe" Source="$(var.SourceDir)/metronome.exe" KeyPath="yes" />
      </Component>
      <Component Id="FlutterEngine" Guid="*">
        <File Id="FlutterDll" Source="$(var.SourceDir)/flutter_windows.dll" />
      </Component>
      <Component Id="C_dartjni_dll" Guid="*">
        <File Id="F_C_dartjni_dll" Source="$(var.SourceDir)/dartjni.dll" />
      </Component>
      <Component Id="C_flutter_soloud_plugin_dll" Guid="*">
        <File Id="F_C_flutter_soloud_plugin_dll" Source="$(var.SourceDir)/flutter_soloud_plugin.dll" />
      </Component>
      <Component Id="C_screen_retriever_windows_plugin_dll" Guid="*">
        <File Id="F_C_screen_retriever_windows_plugin_dll" Source="$(var.SourceDir)/screen_retriever_windows_plugin.dll" />
      </Component>
      <Component Id="C_window_manager_plugin_dll" Guid="*">
        <File Id="F_C_window_manager_plugin_dll" Source="$(var.SourceDir)/window_manager_plugin.dll" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DataComponents">
      <ComponentRef Id="C_app_so" />
      <ComponentRef Id="C_icudtl_dat" />
      <ComponentRef Id="C_flutter_assets_AssetManifest_bin" />
      <ComponentRef Id="C_flutter_assets_FontManifest_json" />
      <ComponentRef Id="C_flutter_assets_NativeAssetsManifest_json" />
      <ComponentRef Id="C_flutter_assets_NOTICES_Z" />
      <ComponentRef Id="C_flutter_assets_assets_help_zh_md" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_drum_click_high_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_drum_click_low_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_electronic_click_high_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_electronic_click_low_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_mechanical_click_high_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_mechanical_click_low_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_voice_click_high_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_voice_click_low_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_woodblock_click_high_wav" />
      <ComponentRef Id="C_flutter_assets_assets_sounds_woodblock_click_low_wav" />
      <ComponentRef Id="C_flutter_assets_fonts_MaterialIcons_Regular_otf" />
      <ComponentRef Id="C_flutter_assets_packages_cupertino_icons_assets_CupertinoIcons_ttf" />
      <ComponentRef Id="C_flutter_assets_shaders_ink_sparkle_frag" />
      <ComponentRef Id="C_flutter_assets_shaders_stretch_effect_frag" />
    </ComponentGroup>
  </Package>
</Wix>
