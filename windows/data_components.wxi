        <Component Id="C_flutter_assets_shaders_stretch_effect_frag" Guid="*"><File Id="F_C_flutter_assets_shaders_stretch_effect_frag" Source="$(var.SourceDir)\data\flutter_assets\shaders\stretch_effect.frag" KeyPath="yes" /></Component>
