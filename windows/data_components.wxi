            <Component Id="C_flutter_assets_assets_sounds_drum_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_drum_click_low_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\drum\click_low.wav" KeyPath="yes" /></Component>
          </Directory>
          <Directory Id="D_flutter_assets_assets_sounds_electronic" Name="electronic">
            <Component Id="C_flutter_assets_assets_sounds_electronic_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_electronic_click_high_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\electronic\click_high.wav" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_assets_sounds_electronic_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_electronic_click_low_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\electronic\click_low.wav" KeyPath="yes" /></Component>
          </Directory>
          <Directory Id="D_flutter_assets_assets_sounds_mechanical" Name="mechanical">
            <Component Id="C_flutter_assets_assets_sounds_mechanical_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_mechanical_click_high_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\mechanical\click_high.wav" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_assets_sounds_mechanical_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_mechanical_click_low_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\mechanical\click_low.wav" KeyPath="yes" /></Component>
          </Directory>
          <Directory Id="D_flutter_assets_assets_sounds_voice" Name="voice">
            <Component Id="C_flutter_assets_assets_sounds_voice_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_voice_click_high_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\voice\click_high.wav" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_assets_sounds_voice_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_voice_click_low_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\voice\click_low.wav" KeyPath="yes" /></Component>
          </Directory>
          <Directory Id="D_flutter_assets_assets_sounds_woodblock" Name="woodblock">
            <Component Id="C_flutter_assets_assets_sounds_woodblock_click_high_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_woodblock_click_high_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\woodblock\click_high.wav" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_assets_sounds_woodblock_click_low_wav" Guid="*"><File Id="F_C_flutter_assets_assets_sounds_woodblock_click_low_wav" Source="$(var.SourceDir)\data\flutter_assets\assets\sounds\woodblock\click_low.wav" KeyPath="yes" /></Component>
