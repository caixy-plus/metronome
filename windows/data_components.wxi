      </Directory>
      <Directory Id="D_flutter_assets_packages" Name="packages">
        <Directory Id="D_flutter_assets_packages_cupertino_icons" Name="cupertino_icons">
          <Directory Id="D_flutter_assets_packages_cupertino_icons_assets" Name="assets">
            <Component Id="C_flutter_assets_packages_cupertino_icons_assets_CupertinoIcons_ttf" Guid="*"><File Id="F_C_flutter_assets_packages_cupertino_icons_assets_CupertinoIcons_ttf" Source="$(var.SourceDir)\data\flutter_assets\packages\cupertino_icons\assets\CupertinoIcons.ttf" KeyPath="yes" /></Component>
          </Directory>
        </Directory>
        <Directory Id="D_flutter_assets_packages_flutter_soloud" Name="flutter_soloud">
          <Directory Id="D_flutter_assets_packages_flutter_soloud_web" Name="web">
            <Component Id="C_flutter_assets_packages_flutter_soloud_web_libflutter_soloud_plugin_js" Guid="*"><File Id="F_C_flutter_assets_packages_flutter_soloud_web_libflutter_soloud_plugin_js" Source="$(var.SourceDir)\data\flutter_assets\packages\flutter_soloud\web\libflutter_soloud_plugin.js" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_packages_flutter_soloud_web_libflutter_soloud_plugin_wasm" Guid="*"><File Id="F_C_flutter_assets_packages_flutter_soloud_web_libflutter_soloud_plugin_wasm" Source="$(var.SourceDir)\data\flutter_assets\packages\flutter_soloud\web\libflutter_soloud_plugin.wasm" KeyPath="yes" /></Component>
            <Component Id="C_flutter_assets_packages_flutter_soloud_web_worker_dart_js" Guid="*"><File Id="F_C_flutter_assets_packages_flutter_soloud_web_worker_dart_js" Source="$(var.SourceDir)\data\flutter_assets\packages\flutter_soloud\web\worker.dart.js" KeyPath="yes" /></Component>
